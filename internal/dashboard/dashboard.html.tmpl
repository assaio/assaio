<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="color-scheme" content="light dark">
<title>assaio — assay report</title>
<style>

/* ---------- tokens ---------- */
:root{
  --bg:#E7E3DA;
  --surface:#F2EFE8;
  --ink:#20211E;
  --muted:#6E6B61;
  --hairline:#CBC6BA;
  --verdigris:#2E8B7F;
  --oxide:#B4652E;
  --brass:#C29B4A;
  --seam:#93B0A4;
  --shadow:0 1px 2px rgba(32,33,30,.07), 0 14px 32px -20px rgba(32,33,30,.35);
  --font-mono:ui-monospace,"SF Mono","JetBrains Mono","Cascadia Code",Menlo,monospace;
  --font-sans:system-ui,-apple-system,"Segoe UI",sans-serif;
  --radius:4px;
  color-scheme:light;
}
@media (prefers-color-scheme:dark){
  :root{
    --bg:#191B19;
    --surface:#212421;
    --ink:#E7E3DA;
    --muted:#8C8A80;
    --hairline:#33352F;
    --verdigris:#39A093;
    --seam:#355A52;
    --shadow:0 1px 2px rgba(0,0,0,.5), 0 16px 36px -20px rgba(0,0,0,.6);
    color-scheme:dark;
  }
}
:root[data-theme="light"]{
  --bg:#E7E3DA; --surface:#F2EFE8; --ink:#20211E; --muted:#6E6B61; --hairline:#CBC6BA;
  --verdigris:#2E8B7F; --seam:#93B0A4;
  --shadow:0 1px 2px rgba(32,33,30,.07), 0 14px 32px -20px rgba(32,33,30,.35);
  color-scheme:light;
}
:root[data-theme="dark"]{
  --bg:#191B19; --surface:#212421; --ink:#E7E3DA; --muted:#8C8A80; --hairline:#33352F;
  --verdigris:#39A093; --seam:#355A52;
  --shadow:0 1px 2px rgba(0,0,0,.5), 0 16px 36px -20px rgba(0,0,0,.6);
  color-scheme:dark;
}

/* ---------- reset ---------- */
*,*::before,*::after{box-sizing:border-box;}
html,body{margin:0;padding:0;}
body{
  background:var(--bg);
  color:var(--ink);
  font-family:var(--font-sans);
  -webkit-font-smoothing:antialiased;
  text-rendering:optimizeLegibility;
}
h1,h2,h3,p,ul,ol,li,table,figure{margin:0;padding:0;}
ul{list-style:none;}
table{border-collapse:collapse;width:100%;}
svg{display:block;}
button{font:inherit;}
.tnum{font-family:var(--font-mono);font-variant-numeric:tabular-nums;}

/* ---------- page / sheet ---------- */
.page{
  min-height:100vh;
  padding:40px 20px 56px;
  display:flex;
  justify-content:center;
}
.sheet{
  width:100%;
  max-width:1080px;
  background:var(--surface);
  border:1px solid var(--hairline);
  border-radius:var(--radius);
  box-shadow:var(--shadow);
  padding:44px 52px 40px;
}

/* ---------- masthead ---------- */
.masthead{
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap:20px;
  flex-wrap:wrap;
  padding-bottom:28px;
  border-bottom:1px solid var(--hairline);
}
.masthead__id{display:flex;align-items:center;gap:14px;}
.hallmark{flex:none;}
.hallmark .punch{fill:var(--verdigris);stroke:var(--ink);stroke-opacity:.35;stroke-width:.6;}
.hallmark .mark{fill:var(--brass);}
.eyebrow{
  font:600 10px/1 var(--font-mono);
  letter-spacing:.14em;
  text-transform:uppercase;
  color:var(--muted);
  margin-bottom:6px;
}
.wordmark{
  font:600 25px/1 var(--font-mono);
  letter-spacing:.01em;
  color:var(--ink);
}
.masthead__status{display:flex;align-items:center;gap:10px;}
.stamp{
  display:inline-flex;
  align-items:center;
  gap:7px;
  font:10px var(--font-mono);
  letter-spacing:.1em;
  text-transform:uppercase;
  color:var(--muted);
  border:1px solid var(--hairline);
  border-radius:3px;
  padding:6px 10px;
}
.stamp__dot{
  width:6px;height:6px;border-radius:50%;
  background:var(--verdigris);
  flex:none;
}
.toggle{
  width:34px;height:30px;
  display:inline-flex;align-items:center;justify-content:center;
  background:var(--surface);
  border:1px solid var(--hairline);
  border-radius:3px;
  color:var(--ink);
  font-size:14px;
  cursor:pointer;
  transition:border-color .15s ease,color .15s ease;
}
.toggle:hover{border-color:var(--verdigris);color:var(--verdigris);}
.toggle:focus-visible{outline:2px solid var(--verdigris);outline-offset:2px;}

/* ---------- panel label (title plate) ---------- */
.panel-label{
  display:flex;
  justify-content:space-between;
  align-items:baseline;
  gap:12px;
  margin:34px 0 10px;
  font-family:var(--font-mono);
  font-size:10px;
  letter-spacing:.12em;
  text-transform:uppercase;
  color:var(--muted);
}
.panel-label strong{color:var(--ink);font-weight:600;}

/* ---------- verdict faceplate (signature) ---------- */
.faceplate{
  display:grid;
  grid-template-columns:repeat(5,1fr);
  gap:1px;
  background:var(--seam);
  border:1px solid var(--hairline);
  border-top:2px solid var(--verdigris);
  border-radius:var(--radius);
  overflow:hidden;
}
.cell{
  background:var(--surface);
  padding:20px 18px 16px;
  display:flex;
  flex-direction:column;
  gap:10px;
}
.cell__label{
  display:block;
  min-height:26px;
  font:600 10px/1.3 var(--font-mono);
  letter-spacing:.1em;
  text-transform:uppercase;
  color:var(--muted);
}
.cell__read-row{display:flex;align-items:center;gap:6px;flex-wrap:wrap;}
.cell__read{
  font:700 19px/1.1 var(--font-mono);
  letter-spacing:.02em;
  text-transform:uppercase;
}
.cell__read--good{color:var(--verdigris);}
.cell__read--watch{color:var(--oxide);}
.cell__read--neutral{color:var(--muted);}
.cell__foot{
  margin-top:auto;
  display:flex;
  flex-direction:column;
  gap:5px;
}
.cell__ratio{
  align-self:flex-end;
  font-size:11px;
  color:var(--muted);
}

/* gauge (purity bar) */
.gauge{
  position:relative;
  height:6px;
  border-radius:3px;
  background:var(--hairline);
}
.gauge::after{
  content:"";
  position:absolute;
  left:50%;top:-2px;bottom:-2px;width:1px;
  background:var(--muted);
  opacity:.4;
}
.gauge__fill{
  position:absolute;inset:0;
  width:var(--fill);
  min-width:3px;
  background:var(--verdigris);
  border-radius:3px;
  animation:fillIn 1.1s cubic-bezier(.4,0,.2,1) both;
}
@keyframes fillIn{from{width:0;}to{width:var(--fill);}}
@media (prefers-reduced-motion:reduce){
  .gauge__fill{animation:none;width:var(--fill);}
}

/* prov stamp */
.prov{
  display:inline-block;
  font:700 8.5px/1 var(--font-mono);
  letter-spacing:.08em;
  text-transform:uppercase;
  color:var(--muted);
  border:1px solid var(--hairline);
  border-radius:2px;
  padding:2px 5px;
  transform:rotate(-3deg);
}

/* ---------- ledger ---------- */
.ledger{margin-top:6px;}
.entry{
  display:grid;
  grid-template-columns:150px 1fr;
  column-gap:32px;
  padding:30px 0;
  border-top:1px solid var(--hairline);
}
.entry:first-child{border-top:none;padding-top:22px;}
.entry__gutter{display:flex;flex-direction:column;gap:8px;}
.entry__num{
  font:300 32px/1 var(--font-mono);
  color:var(--muted);
  letter-spacing:-.02em;
}
.entry__label{
  font:600 11px/1.3 var(--font-mono);
  letter-spacing:.06em;
  text-transform:uppercase;
  color:var(--ink);
}
.entry__read{font:700 15px/1.1 var(--font-mono);letter-spacing:.02em;text-transform:uppercase;}
.entry__read--good{color:var(--verdigris);}
.entry__read--watch{color:var(--oxide);}
.entry__read--neutral{color:var(--muted);}

.entry__stats{display:flex;flex-wrap:wrap;gap:26px 34px;}
.stat{display:flex;flex-direction:column;gap:5px;}
.stat__value{font:600 clamp(21px,3.4vw,30px)/1 var(--font-mono);color:var(--ink);}
.stat__value--accent{color:var(--verdigris);}
.stat__label{font:10px var(--font-mono);letter-spacing:.08em;text-transform:uppercase;color:var(--muted);}
.stat__note{font:10px var(--font-mono);color:var(--muted);}

.entry__viz{margin-top:20px;max-width:460px;}
.entry__empty{margin-top:4px;font:12px var(--font-mono);color:var(--muted);}
.entry__howto{
  margin-bottom:16px;
  font:13px/1.5 var(--font-sans);
  color:var(--muted);
  max-width:52ch;
}
.entry__howto::before{content:"How to read — ";color:var(--muted);}
.entry__caveat{
  margin-top:14px;
  font:13px/1.5 var(--font-sans);
  color:var(--muted);
  max-width:52ch;
}
.entry__caveat::before{content:"Note — ";color:var(--muted);}
.entry__takeaway{
  margin-top:18px;
  font:14px/1.55 var(--font-sans);
  color:var(--ink);
  max-width:52ch;
}
.entry__takeaway::before{content:"— ";color:var(--muted);}

/* ranked bar list (model/project breakdowns) */
.projectbars{display:flex;flex-direction:column;gap:9px;}
.projectbars li{display:flex;align-items:center;gap:12px;}
.projectbars__name{width:150px;flex:none;font:11px var(--font-mono);color:var(--ink);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.projectbars__bar{flex:1;height:8px;background:var(--hairline);border-radius:2px;overflow:hidden;}
.projectbars__bar span{display:block;height:100%;background:var(--verdigris);border-radius:2px;}
.projectbars__value{width:150px;flex:none;text-align:right;font-size:12px;color:var(--ink);}

/* ---------- team (per-member adoption breakdown) ---------- */
.team{margin-top:8px;}
.teamlist{display:flex;flex-direction:column;gap:10px;margin-top:4px;}
.teamlist li{display:flex;align-items:center;gap:14px;}
.teamlist__name{width:120px;flex:none;font:11px var(--font-mono);color:var(--ink);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.teamlist__bar{flex:1 1 140px;height:8px;min-width:80px;background:var(--hairline);border-radius:2px;overflow:hidden;}
.teamlist__bar span{display:block;height:100%;background:var(--verdigris);border-radius:2px;}
.teamlist__stats{display:flex;flex:none;gap:16px;font-size:11px;color:var(--muted);}

/* ---------- drilldown ---------- */
.drilldown{margin-top:8px;}
.section-title{
  font:600 14px/1.2 var(--font-mono);
  letter-spacing:.04em;
  color:var(--ink);
}
.section-title em{font-style:normal;color:var(--verdigris);}
.section-sub{
  margin-top:6px;
  font:13px/1.5 var(--font-sans);
  color:var(--muted);
  max-width:52ch;
}
.drilldown__stats{display:flex;gap:34px;margin:20px 0 22px;}
.faceplate--compact{margin-bottom:24px;}
.faceplate--compact .cell{padding:14px 14px 12px;gap:7px;}
.faceplate--compact .cell__label{font-size:9px;}
.faceplate--compact .cell__read{font-size:15px;}
.faceplate--compact .cell__ratio{display:none;}
.faceplate--compact .gauge{height:5px;}

.table-scroll{overflow-x:auto;margin-top:4px;}
table.subpath{min-width:480px;}
table.subpath th{
  text-align:left;
  font:600 10px var(--font-mono);
  letter-spacing:.08em;
  text-transform:uppercase;
  color:var(--muted);
  padding:0 14px 10px 0;
  border-bottom:1px solid var(--hairline);
}
table.subpath td{
  font:13px var(--font-mono);
  color:var(--ink);
  padding:11px 14px 11px 0;
  border-bottom:1px solid var(--hairline);
}
table.subpath th:not(:first-child),
table.subpath td:not(:first-child){text-align:right;}
table.subpath tfoot td{
  border-bottom:none;
  border-top:1px solid var(--hairline);
  font-weight:600;
  color:var(--ink);
  padding-top:11px;
}
table.subpath tbody tr:hover td{background:var(--bg);}
.eyebrow-sm{
  font:600 10px var(--font-mono);
  letter-spacing:.12em;
  text-transform:uppercase;
  color:var(--muted);
  margin-bottom:10px;
  display:block;
}
.scroll-hint{display:none;font-weight:400;text-transform:none;letter-spacing:0;color:var(--muted);}

/* ---------- cost footnote ---------- */
.footnote{
  margin-top:40px;
  padding-top:18px;
  border-top:1px solid var(--hairline);
  font:11px var(--font-mono);
  letter-spacing:.02em;
  color:var(--muted);
}
.footnote strong{color:var(--ink);font-weight:600;}

/* ---------- colophon ---------- */
.colophon{
  margin-top:22px;
  display:flex;
  flex-direction:column;
  gap:5px;
}
.colophon p{
  font:9.5px/1.6 var(--font-mono);
  letter-spacing:.07em;
  text-transform:uppercase;
  color:var(--muted);
}

/* ---------- responsive ---------- */
@media (max-width:880px){
  .sheet{padding:36px 32px 32px;}
  .faceplate{grid-template-columns:repeat(3,1fr);}
  .faceplate .cell:last-child{grid-column:span 2;}
  .entry{grid-template-columns:130px 1fr;column-gap:22px;}
  .projectbars__name{width:120px;}
  .projectbars__value{width:130px;}
}
@media (max-width:640px){
  .page{padding:24px 12px 40px;}
  .sheet{padding:26px 20px 26px;border-radius:3px;}
  .faceplate{grid-template-columns:repeat(2,1fr);}
  .wordmark{font-size:22px;}
  .panel-label{flex-direction:column;align-items:flex-start;gap:3px;}
  .entry{grid-template-columns:1fr;row-gap:14px;}
  .entry__gutter{flex-direction:row;align-items:baseline;gap:10px;flex-wrap:wrap;}
  .entry__num{font-size:22px;}
  .drilldown__stats{gap:24px;flex-wrap:wrap;}
  .projectbars li{flex-wrap:wrap;}
  .projectbars__name{width:auto;flex:1 1 auto;}
  .projectbars__value{width:auto;}
  .projectbars__bar{flex:1 1 100%;order:3;margin-top:2px;}
  .teamlist li{flex-wrap:wrap;}
  .teamlist__name{width:auto;flex:1 1 auto;}
  .teamlist__bar{flex:1 1 100%;order:3;margin-top:2px;}
  .scroll-hint{display:inline;}
  table.subpath{min-width:420px;}
}
@media (max-width:380px){
  .sheet{padding:20px 14px 22px;}
  .masthead{gap:14px;}
  .cell{padding:16px 14px 14px;}
  .entry__stats{gap:18px 24px;}
  table.subpath{min-width:380px;font-size:12px;}
}
</style>
</head>
<body>
<div class="page">
<main class="sheet">

  <header class="masthead">
    <div class="masthead__id">
      <svg class="hallmark" width="28" height="28" viewBox="0 0 28 28" aria-hidden="true" focusable="false">
        <polygon class="punch" points="14,1.2 25.2,7.6 25.2,20.4 14,26.8 2.8,20.4 2.8,7.6"/>
        <rect class="mark" x="11" y="11" width="6" height="6" transform="rotate(45 14 14)"/>
      </svg>
      <div class="masthead__word">
        <p class="eyebrow">{{(locale).ReportEyebrow}} · {{.Window}}</p>
        <h1 class="wordmark">assaio</h1>
      </div>
    </div>
    <div class="masthead__status">
      <span class="stamp"><i class="stamp__dot"></i>{{(locale).StatusChip}}</span>
      <button id="themeToggle" class="toggle" type="button" aria-label="{{(locale).ToggleDarkLabel}}">☾</button>
    </div>
  </header>

  <div class="panel-label">
    <span><strong>{{(locale).VerdictLabel}}</strong> · {{len .Verdicts}} {{(locale).ReadsSuffix}}</span>
    <span>{{.Inventory.Projects}} {{(locale).ProjectsSuffix}} · {{.Window}}</span>
  </div>

  {{/* EXTENSIBILITY SEAM: both ranges below iterate Data.Verdicts, the single source of
       truth analyze.Validators() produces. A newly registered analyze.Validator needs no
       change here -- it gets a faceplate cell and a ledger entry automatically. */}}
  <section class="faceplate" aria-label="{{(locale).VerdictLabel}}, {{len .Verdicts}} {{(locale).DimensionsSuffix}}">
    {{range facets .Verdicts}}{{template "faceplateCell" .}}{{end}}
  </section>

  <div class="panel-label">
    <span><strong>{{(locale).AssayLabel}}</strong> · {{(locale).AllProjects}}</span>
    <span>{{.Inventory.Sessions}} {{(locale).SessionsLabel}} · {{.Inventory.ActiveDays}} {{(locale).ActiveDaysSuffix}}</span>
  </div>

  <section class="ledger">
    {{range facets .Verdicts}}{{template "ledgerEntry" .}}{{end}}
  </section>

  {{with .Drill}}
  <section class="drilldown">
    <h2 class="section-title">{{(locale).AssayLabel}} · <em>{{.Name}}</em></h2>
    <p class="section-sub">{{(locale).DrillSubtitle}}</p>

    <div class="drilldown__stats">
      <div class="stat"><span class="stat__value tnum">{{.Lines}}</span><span class="stat__label">{{(locale).AILinesLabel}}</span></div>
      <div class="stat"><span class="stat__value tnum">{{.Sessions}}</span><span class="stat__label">{{(locale).SessionsLabel}}</span></div>
    </div>

    <div class="faceplate faceplate--compact">
      {{range facets .Verdicts}}{{template "faceplateCell" .}}{{end}}
    </div>

    <span class="eyebrow-sm">{{(locale).SubpathBreakdown}} <span class="scroll-hint">{{(locale).ScrollHint}}</span></span>
    <div class="table-scroll">
      <table class="subpath">
        <thead>
          <tr><th>{{(locale).SubpathColumn}}</th><th>{{(locale).AILinesLabel}}</th><th>{{(locale).SessionsLabel}}</th></tr>
        </thead>
        <tbody>
          {{range .Subpaths}}
          <tr><td>{{subpathName .Subpath}}</td><td class="tnum">{{.Lines}}</td><td class="tnum">{{.Sessions}}</td></tr>
          {{else}}
          <tr><td colspan="3">{{(locale).NoSubpathData}}</td></tr>
          {{end}}
        </tbody>
        <tfoot>
          <tr><td>{{(locale).TotalRow}}</td><td class="tnum">{{.Lines}}</td><td class="tnum">{{.Sessions}}</td></tr>
        </tfoot>
      </table>
    </div>
  </section>
  {{end}}

  {{with .Team}}
  <section class="team">
    <div class="panel-label">
      <span><strong>{{(locale).TeamPanelLabel}}</strong></span>
      <span>{{len .Stats}} {{(locale).MembersSuffix}}</span>
    </div>
    <p class="section-sub">{{(locale).TeamCaption}}</p>
    <ul class="teamlist">
      {{range .Stats}}
      <li>
        <span class="teamlist__name">{{.Member}}</span>
        <span class="teamlist__bar"><span style="width:{{pct .Frac}}%"></span></span>
        <span class="teamlist__stats tnum">
          <span>{{.Sessions}} {{(locale).SessionsLabel}}</span>
          <span>{{.LinesAdded}} {{(locale).AILinesLabel}}</span>
          <span>{{.CostDisplay}}</span>
        </span>
      </li>
      {{end}}
    </ul>
  </section>
  {{end}}

  <p class="footnote">{{(locale).CostBasisPrefix}} · <strong class="tnum">{{.CostBasis}}</strong> · {{(locale).CostBasisSuffix}}</p>

  <footer class="colophon">
    {{range .Caveats}}<p>{{.}}</p>{{end}}
  </footer>

</main>
</div>

<script>
(function(){
  var root=document.documentElement;
  var stored=null;
  try{stored=localStorage.getItem('assaio-theme');}catch(e){}
  var mql=window.matchMedia('(prefers-color-scheme: dark)');
  var theme=stored||(mql.matches?'dark':'light');
  root.setAttribute('data-theme',theme);

  function paint(){
    var btn=document.getElementById('themeToggle');
    if(!btn)return;
    btn.textContent=theme==='dark'?'☀':'☾';
    btn.setAttribute('aria-label',theme==='dark'?'Switch to light theme':'Switch to dark theme');
  }
  function init(){
    paint();
    var btn=document.getElementById('themeToggle');
    btn.addEventListener('click',function(){
      theme=theme==='dark'?'light':'dark';
      root.setAttribute('data-theme',theme);
      try{localStorage.setItem('assaio-theme',theme);}catch(e){}
      paint();
    });
  }
  if(document.readyState==='loading'){
    document.addEventListener('DOMContentLoaded',init);
  }else{
    init();
  }
})();
</script>
</body>
</html>

{{/* faceplateCell renders one faceplate cell from a facetView {N, R analyze.Result}.
     Reused by the top-level faceplate and the drill's compact faceplate -- CSS alone
     (.faceplate--compact) handles the size/ratio-visibility difference between them. */}}
{{define "faceplateCell"}}
<div class="cell">
  <span class="cell__label">{{printf "%02d" .N}} · {{.R.Title}}</span>
  <div class="cell__read-row">
    <span class="cell__read cell__read--{{.R.Read.Key}}">{{.R.Read.Label}}</span>
    {{if .R.Caveats}}<span class="prov">{{(locale).ProvLabel}}</span>{{end}}
  </div>
  <div class="cell__foot">
    <div class="gauge"><span class="gauge__fill" style="--fill:{{pct .R.Purity}}%"></span></div>
    <span class="cell__ratio tnum">{{printf "%.2f" .R.Purity}}</span>
  </div>
</div>
{{end}}

{{/* ledgerEntry renders one assay ledger entry generically off a facetView's Result:
     Figures become stat tiles, Bars (when non-nil) become a ranked bar list, Caveats
     surface the "Prov." stamp and an honesty note, and Takeaway closes the entry. A new
     validator needs no change here. */}}
{{define "ledgerEntry"}}
<article class="entry">
  <div class="entry__gutter">
    <span class="entry__num">{{printf "%02d" .N}}</span>
    <span class="entry__label">{{.R.Title}}</span>
    <div class="cell__read-row">
      <span class="entry__read entry__read--{{.R.Read.Key}}">{{.R.Read.Label}}</span>
      {{if .R.Caveats}}<span class="prov">{{(locale).ProvLabel}}</span>{{end}}
    </div>
  </div>
  <div>
    {{if .R.HowToRead}}<p class="entry__howto">{{.R.HowToRead}}</p>{{end}}
    {{if .R.Figures}}
    <div class="entry__stats">
      {{range $j, $f := .R.Figures}}
      <div class="stat">
        <span class="stat__value{{if eq $j 0}} stat__value--accent{{end}}">{{$f.Value}}</span>
        <span class="stat__label">{{$f.Label}}</span>
        {{if $f.Note}}<span class="stat__note">{{$f.Note}}</span>{{end}}
      </div>
      {{end}}
    </div>
    {{end}}
    {{if barsApplicable .R}}
    <div class="entry__viz">
      {{if .R.Bars}}
      <ul class="projectbars">
        {{range .R.Bars}}
        <li>
          <span class="projectbars__name">{{.Label}}</span>
          <span class="projectbars__bar"><span style="width:{{pct .Frac}}%"></span></span>
          <span class="projectbars__value tnum">{{.Value}}</span>
        </li>
        {{end}}
      </ul>
      {{else}}
      <p class="entry__empty">{{(locale).NoBarsInWindow}}</p>
      {{end}}
    </div>
    {{end}}
    {{range .R.Caveats}}<p class="entry__caveat">{{.}}</p>{{end}}
    <p class="entry__takeaway">{{.R.Takeaway}}</p>
  </div>
</article>
{{end}}
